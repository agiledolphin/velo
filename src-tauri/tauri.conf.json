{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Velo",
  "version": "0.2.0",
  "identifier": "app.velo.desktop",
  "build": {
    "beforeDevCommand": "bun run engine:prepare-sidecar && bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run engine:prepare-sidecar && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Velo / 微落",
        "width": 1120,
        "height": 660,
        "minWidth": 920,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": {
          "x": 18,
          "y": 18
        }
      }
    ],
    "security": {
      "capabilities": ["default"],
      "csp": {
        "default-src": "'none'",
        "script-src": "'self'",
        "style-src": "'self'",
        "font-src": "'self'",
        "img-src": "'self' data:",
        "connect-src": "ipc: http://ipc.localhost",
        "object-src": "'none'",
        "base-uri": "'none'",
        "form-action": "'none'",
        "frame-src": "'none'",
        "frame-ancestors": "'none'",
        "media-src": "'none'",
        "worker-src": "'none'",
        "manifest-src": "'none'"
      },
      "devCsp": {
        "default-src": "'none'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self'",
        "img-src": "'self' data: blob:",
        "connect-src": "'self' ipc: http://ipc.localhost ws://localhost:1420",
        "object-src": "'none'",
        "base-uri": "'none'",
        "form-action": "'none'",
        "frame-src": "'none'",
        "frame-ancestors": "'none'",
        "media-src": "'none'",
        "worker-src": "'none'",
        "manifest-src": "'none'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/yt-dlp", "binaries/ffmpeg", "binaries/deno"],
    "resources": ["resources/THIRD_PARTY_NOTICES.md"],
    "category": "Utility",
    "shortDescription": "轻取流光，留住此刻。",
    "longDescription": "Velo / 微落是一款简洁的桌面视频保存工具。"
  }
}
