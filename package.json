{
  "name": "velo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "bun run engine:verify && bun run tauri dev",
    "build": "tsc --noEmit && vite build",
    "build:desktop": "bun run tauri build",
    "engine:install": "bun scripts/install-engine.ts",
    "engine:prepare-sidecar": "bun scripts/prepare-sidecar.ts",
    "engine:verify": "bun scripts/verify-engine.ts",
    "preview": "vite preview",
    "test": "vitest run",
    "test:integration": "cargo test --manifest-path src-tauri/Cargo.toml infrastructure::yt_dlp_engine::tests::inspects_configured_real_url -- --ignored --exact --nocapture",
    "test:watch": "vitest",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "2.11.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "6.0.3",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
